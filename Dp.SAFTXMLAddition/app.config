<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="LoggerSettings" type="Dominos.LogForPulse.ConfigSectionHandler,Dp.LogForPulse"/>
  </configSections>
  <LoggerSettings>
    <OutputType>File</OutputType>
    <LogDebugMessages>false</LogDebugMessages>
    <SummerizeRepeatedErrors>false</SummerizeRepeatedErrors>
  </LoggerSettings>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.1"/></startup></configuration>
