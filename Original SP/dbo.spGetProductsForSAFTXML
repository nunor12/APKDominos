ALTER PROCEDURE [dbo].[spGetProductsForSAFTXML]
(
	@LocationCode AS NVARCHAR(8), 
	@ProductCodes AS NVARCHAR(MAX)
)
AS  
BEGIN
SET NOCOUNT ON

DECLARE	@LanguageCode AS SMALLINT
SET @LanguageCode=dbo.udfSYSGetSystemSetting(@LocationCode,'Default_Language_Code')

	SELECT DISTINCT 
			P.ProductCode,
			P.ProductCategoryCode,
			PT.ProdTextProductDesc 
	FROM [dbo].[Products] (NOLOCK) AS P 
		INNER JOIN [dbo].[ProductsText] (NOLOCK) AS PT ON 
			(
				P.ProductCode=PT.ProductCode
				AND P.Location_Code=PT.Location_Code
				AND PT.Language_Code=@LanguageCode
			)
	WHERE
		(
			P.Location_Code=@LocationCode 
			AND P.ProductCode IN (SELECT * FROM dbo.udfSplit(@ProductCodes ,'|'))
		)
END